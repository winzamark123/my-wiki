/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "wiki-app",
	"account_id": "e62b5d31403985d71d0a4faae9948728",
	"compatibility_date": "2026-07-11",
	"main": "./workers/app.ts",
	// keep write routes unreachable until a custom domain is protected by Access
	"workers_dev": false,
	"preview_urls": false,
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": ["nodejs_compat", "enable_request_signal"],
	// edge-caches responses per Cache-Control headers; hits skip the Worker
	"cache": { "enabled": true },
	"r2_buckets": [
		{
			"binding": "WIKI",
			"bucket_name": "my-wiki"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "RED_LINK_STREAM",
				"class_name": "ResumableStreamDO"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["ResumableStreamDO"]
		}
	],
	"workflows": [
		{
			"name": "synthesis",
			"binding": "SYNTHESIS_WORKFLOW",
			"class_name": "SynthesisWorkflow"
		}
	],
	"vars": {
		"OPENAI_BASE_URL": "https://gateway.ai.cloudflare.com/v1/e62b5d31403985d71d0a4faae9948728/my-wiki/openai",
		"OPENAI_MODEL": "gpt-5.6-sol"
	}
}
